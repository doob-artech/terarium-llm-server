PORT=18200
HOST=0.0.0.0

# world-server/tutor/routine tools call this server with Bearer auth.
LLM_SERVER_API_KEYS=change-me

# Required for worker management endpoints.
LLM_SERVER_ADMIN_KEY=change-me-admin
LLM_SERVER_INSTANCE_KEY=change-me-instance

# Default model for requests that omit model.
DEFAULT_MODEL=igorls/gemma-4-E4B-it-heretic-GGUF:Q4_K_M
DEFAULT_WORKER_POOL=slm
WORKER_POOLS=slm,llm

# 0 means no application-level timeout. Upstream/proxy may still have its own timeout.
REQUEST_TIMEOUT_MS=0

# Worker healthcheck controls automatic availability.
WORKER_HEALTHCHECK_ENABLED=true
WORKER_HEALTHCHECK_INTERVAL_MS=15000
WORKER_HEALTHCHECK_TIMEOUT_MS=3000
WORKER_UNHEALTHY_AFTER_FAILURES=2
WORKER_HEALTHY_AFTER_SUCCESSES=1
WORKER_REGISTRY_SEED_EXAMPLE=true

# Autoscaling is safe by default. Set AUTOSCALE_ENABLED=true and AUTOSCALE_DRY_RUN=false to create/destroy RunPod instances.
AUTOSCALE_ENABLED=false
AUTOSCALE_DRY_RUN=true
AUTOSCALE_PROVIDERS=runpod-community,runpod-secure
AUTOSCALE_INTERVAL_MS=5000
AUTOSCALE_SCALE_UP_COOLDOWN_MS=120000
AUTOSCALE_PENDING_INSTANCE_TIMEOUT_MS=180000
AUTOSCALE_SUSTAINED_BACKLOG_MS=60000
AUTOSCALE_SCALE_DOWN_IDLE_MS=300000
AUTOSCALE_MIN_WORKERS=0
AUTOSCALE_MAX_WORKERS=14
AUTOSCALE_FAILED_OFFER_COOLDOWN_MS=300000
AUTOSCALE_BACKLOG_PER_WORKER=2
AUTOSCALE_TARGET_UTILIZATION=0.82
AUTOSCALE_SCALE_DOWN_UTILIZATION=0.25
AUTOSCALE_TARGET_REQUESTS_PER_SECOND=0.8
AUTOSCALE_SINGLE_GPU_ONLY=true
AUTOSCALE_WORKER_POOL=llm
AUTOSCALE_WORKER_MODEL=igorls/gemma-4-12B-it-heretic-GGUF:Q4_K_M
AUTOSCALE_DISK_GB=16
AUTOSCALE_INSTANCE_PORT=11434
AUTOSCALE_ROUTER_PORT=18080
AUTOSCALE_OLLAMA_BASE_PORT=11540
AUTOSCALE_REGISTER_PER_GPU=true
AUTOSCALE_DOCKER_IMAGE=ollama/ollama:latest

RUNPOD_API_KEY=
RUNPOD_MAX_DOLLARS_PER_HOUR=0.35
RUNPOD_CONTAINER_DISK_GB=30
RUNPOD_VOLUME_GB=0
RUNPOD_MIN_VCPU_COUNT=2
RUNPOD_MIN_MEMORY_GB=15
RUNPOD_DOCKER_IMAGE=ollama/ollama:latest

# Worker registry is persisted here so operators can add/remove workers without code changes.
# In production, worker base URLs should point to Tailscale/private endpoints, not Cloudflare public domains.
WORKER_REGISTRY_BACKEND=postgres
WORKER_REGISTRY_PATH=./data/workers.json
INSTANCE_REGISTRY_PATH=./data/instances.json

INSTANCE_MONITOR_ENABLED=true
INSTANCE_MONITOR_INTERVAL_MS=15000
INSTANCE_STALE_AFTER_MS=60000
INSTANCE_CLEANUP_AFTER_MS=180000
INSTANCE_DEREGISTER_MISSING_WORKERS=true
INSTANCE_CLEANUP_REMOVES_WORKERS=true

# Used when WORKER_REGISTRY_BACKEND=postgres.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=terarium_memory
POSTGRES_USER=terarium
POSTGRES_PASSWORD=change-me
POSTGRES_SSL=false

# If true, /v1/chat/completions accepts requests without Authorization.
ALLOW_NO_AUTH=false
